rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 🔐 HELPER FUNCTIONS
    // ============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }
    
    function isValidTimestamp(value) {
      return value is timestamp;
    }
    
    function isValidNumber(value) {
      return value is number;
    }
    
    function isArray(value) {
      return value is list;
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    // ============================================================
    // 👤 USERS COLLECTION
    // ============================================================
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isOwner(userId) 
        && isValidString(resource.data.displayName, 1, 100)
        && request.resource.data.keys().hasAll(['displayName', 'email']);
      allow update: if isOwner(userId) 
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'followingCount', 'postCount']));
      allow delete: if isOwner(userId);
      
      // User settings subcollection
      match /settings/{settingId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
      
      // Push tokens subcollection
      match /push_tokens/{tokenId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
    
    // ============================================================
    // 📝 POSTS COLLECTION
    // ============================================================
    match /posts/{postId} {
      allow read: if true; // Public posts
      
      allow create: if isSignedIn() 
        && isOwner(request.resource.data.authorId)
        && isValidString(request.resource.data.content, 0, 10000)
        && request.resource.data.createdAt == request.time;
      
      allow update: if isSignedIn() && (
        isOwner(resource.data.authorId) ||
        (resource.data.moderationStatus == 'pending' && isAdmin())
      ) && (
        // Authors can only modify specific fields
        (isOwner(resource.data.authorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'content', 'visibility', 'editedAt', 'edited', 'media', 'tags', 'location'
        ])) ||
        // Admins can update moderation
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderationStatus', 'moderationNotes', 'moderatedAt'
        ]))
      );
      
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
      
      // Likes subcollection
      match /likes/{likeId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && isOwner(request.resource.data.userId);
      }
      
      // Views subcollection
      match /views/{viewId} {
        allow read: if isOwner(resource.data.authorId) || isAdmin();
        allow create: if isSignedIn();
      }
    }
    
    // ============================================================
    // 💬 COMMENTS COLLECTION
    // ============================================================
    match /comments/{commentId} {
      allow read: if true;
      
      allow create: if isSignedIn()
        && isValidString(request.resource.data.text, 1, 2000)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        isAdmin()
      ) && (
        (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text', 'editedAt', 'edited', 'isHidden'
        ])) ||
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderationStatus', 'isHidden', 'moderationNotes'
        ]))
      );
      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
      
      // Replies subcollection
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }
    
    // ============================================================
    // 📖 STORIES COLLECTION
    // ============================================================
    match /stories/{storyId} {
      allow read: if true;
      
      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId)
        && request.resource.data.createdAt == request.time;
      
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
      
      // Story views
      match /views/{viewId} {
        allow read: if isOwner(resource.data.userId);
        allow create: if isSignedIn();
      }
    }
    
    // ============================================================
    // 💬 CONVERSATIONS & MESSAGES
    // ============================================================
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() 
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.createdAt == request.time;
        allow update: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'readBy', 'editedAt', 'isDeleted', 'reactions'
            ]) ||
            isAdmin()
          );
        allow delete: if isOwner(resource.data.senderId) || isAdmin();
      }
    }
    
    // Direct messages collection (alternative structure)
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && (request.resource.data.recipientId == request.auth.uid || request.resource.data.recipientId is string);
      allow update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isOwner(resource.data.senderId) || isAdmin();
    }
    
    // ============================================================
    // 👥 FOLLOWS COLLECTION
    // ============================================================
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow delete: if isSignedIn() && 
        (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
    }
    
    // ============================================================
    // 🚫 BLOCKS COLLECTION
    // ============================================================
    match /blocks/{blockId} {
      allow read: if isSignedIn() && 
        (resource.data.blockerId == request.auth.uid || resource.data.blockedId == request.auth.uid);
      allow create, delete: if isSignedIn() && request.resource.data.blockerId == request.auth.uid;
    }
    
    // ============================================================
    // 🔔 NOTIFICATIONS COLLECTION
    // ============================================================
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.recipientId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }
    
    // ============================================================
    // 🪙 COIN TRANSACTIONS (Server-controlled)
    // ============================================================
    match /coin_transactions/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // ============================================================
    // 🎬 VIDEOS COLLECTION
    // ============================================================
    match /videos/{videoId} {
      allow read: if true;
      
      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId)
        && request.resource.data.createdAt == request.time;
      
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
      
      // Video likes
      match /likes/{likeId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && isOwner(request.resource.data.userId);
      }
      
      // Video comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }
    
    // ============================================================
    // 📚 COLLECTIONS / SAVED POSTS
    // ============================================================
    match /saved_posts/{savedId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // ❤️ LIKED POSTS
    // ============================================================
    match /liked_posts/{likeId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // 📋 FRIEND REQUESTS
    // ============================================================
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && 
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow delete: if isSignedIn() && 
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }
    
    // ============================================================
    // 📊 USER REPORTS
    // ============================================================
    match /user_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ============================================================
    // 🚨 MESSAGE REPORTS
    // ============================================================
    match /message_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================================
    // 📢 ADS & SPONSORED POSTS
    // ============================================================
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /sponsored_posts/{sponsoredId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /ad_impressions/{impressionId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // ============================================================
    // 💰 VIDEO PURCHASES
    // ============================================================
    match /video_purchases/{purchaseId} {
      allow read: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Server-controlled
    }
    
    // ============================================================
    // ⏱️ SCHEDULED MESSAGES
    // ============================================================
    match /scheduled_messages/{schedId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // 🎯 PUSH QUEUE (Server-side)
    // ============================================================
    match /push_queue/{pushId} {
      allow read: if isAdmin();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 🔄 FANOUT TASKS (Server-side)
    // ============================================================
    match /fanout_tasks/{taskId} {
      allow read: if isAdmin();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 💬 MESSAGE DEDUPLICATION
    // ============================================================
    match /message_dedupe/{dedupeId} {
      allow read: if isAdmin();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // ⚡ RATE LIMITS
    // ============================================================
    match /rate_limits/{limitId} {
      allow read: if isSignedIn();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 👥 GROUP INVITES
    // ============================================================
    match /group_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && 
        (resource.data.inviteeId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // ============================================================
    // 📱 DEVICES & SESSIONS
    // ============================================================
    match /devices/{deviceId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    match /user_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // 📊 USER EVENTS / ANALYTICS
    // ============================================================
    match /user_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================================
    // 📞 CALLS (WebRTC Signaling)
    // ============================================================
    match /calls/{callId} {
      allow read: if isSignedIn() && 
        (resource.data.callerId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.callerId == request.auth.uid;
      allow update: if isSignedIn() && 
        (resource.data.callerId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow delete: if isSignedIn() && 
        (resource.data.callerId == request.auth.uid || isAdmin());
      
      match /signals/{signalId} {
        allow read: if isSignedIn() && 
          (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      }
    }
    
    // ============================================================
    // 🔢 SHARDS (Counter Sharding)
    // ============================================================
    match /shards/{shardId} {
      allow read: if isSignedIn();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 📹 HIGHLIGHTS
    // ============================================================
    match /highlights/{highlightId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // 📚 ARCHIVED STORIES
    // ============================================================
    match /archived_stories/{storyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // 🎵 AUDIO LIBRARY
    // ============================================================
    match /audio_tracks/{trackId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // ============================================================
    // 📁 REPORT IMPRESSIONS
    // ============================================================
    match /report_impressions/{impressionId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================================
    // 🏷️ HASHTAGS
    // ============================================================
    match /hashtags/{hashtagId} {
      allow read: if true;
      allow update: if isAdmin();
    }
    
    // ============================================================
    // 🏷️ REPORTS (Content Reports)
    // ============================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================================
    // 📝 IDEMPOTENCY KEYS (Server-side)
    // ============================================================
    match /idempotency_keys/{keyId} {
      allow read: if isAdmin();
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 👑 ADMINS COLLECTION
    // ============================================================
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only Firebase Admin SDK
    }
    
    // ============================================================
    // 🏷️ USERNAME MAPPING
    // ============================================================
    match /usernames/{username} {
      allow read: if true;
      allow write: if false; // Server-controlled
    }
    
    // ============================================================
    // 🔒 DEFAULT DENY - Catch all
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
